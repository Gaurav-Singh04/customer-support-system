{
  "name": "@swades/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "db:generate": "drizzle-kit generate --name initial_schema",
    "db:migrate": "node --env-file=../../.env --import=tsx src/migrate.ts",
    "db:seed": "node --env-file=../../.env --import=tsx src/seed.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.6",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6"
  }
}
